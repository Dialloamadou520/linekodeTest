# Configuration DexpayAfrica
# Copiez ce fichier en .env et remplissez avec vos vraies clés API

# Clés API DexpayAfrica (Production)
DEXPAY_API_KEY=pk_live_VOTRE_CLE_PUBLIQUE_ICI
DEXPAY_SECRET_KEY=sk_live_VOTRE_CLE_SECRETE_ICI

# URL de base de l'API
DEXPAY_BASE_URL=https://api.dexpay.africa/api/v1

# Mode (true pour sandbox/test, false pour production)
DEXPAY_SANDBOX_MODE=false

# URLs de redirection (à adapter selon votre domaine)
SITE_URL=https://linekode.com
SUCCESS_URL=https://linekode.com/payment-success.php
FAILURE_URL=https://linekode.com/payment-cancelled.php
WEBHOOK_URL=https://linekode.com/api/dexpay-webhook.php

# Configuration du site
SITE_NAME=Linekode
SITE_EMAIL=contact@linekode.com
ADMIN_EMAIL=admin@linekode.com

# Montant de l'inscription (en FCFA)
INSCRIPTION_AMOUNT=50000

# Pays et devise
COUNTRY_ISO=SN
CURRENCY=XOF

# Configuration email (optionnel)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=

# Base de données (si vous en utilisez une)
DB_HOST=localhost
DB_NAME=linekode_db
DB_USER=root
DB_PASSWORD=
